{
  "buildCommand": "npx prisma generate && npm run build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/fetch-topics",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/process-tasks",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/wander",
      "schedule": "0 0 * * *"
    }
  ]
}
