{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Chromium debug mode",
      "type": "chrome",
      "request": "launch",
      "runtimeExecutable": "/Applications/Chromium.app/Contents/MacOS/Chromium",
      "runtimeArgs": [
        "--remote-debugging-port=9222",
        "--user-data-dir=remote-debug-profile"
      ],
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}",
      "timeout": 30000
    },
    {
      "name": "DEBUG: fullstack",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm dev",
      "serverReadyAction": {
        "pattern": "Local:.*?(https?://localhost:\\d+)",
        "action": "startDebugging",
        "name": "Chromium debug mode"
      }
    }
  ]
}
