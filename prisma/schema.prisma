// SecondMe 雅典学院 - 知识广场 Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 用户表 - 存储 SecondMe OAuth 用户信息
model User {
  id                     String    @id @default(cuid())
  secondmeUserId         String    @unique
  nickname               String?
  avatarUrl              String?
  email                  String?
  accessToken            String
  refreshToken           String
  tokenExpiresAt         DateTime
  autoSubscribeNewTopics Boolean   @default(false) // 自动订阅每日新话题
  lastReadReportsAt      DateTime? // 上次访问 reports 页面时间（用于计算未读报告数）
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  // 关联
  posts            Post[]
  subscriptions    Subscription[]
  agentTasks       AgentTask[]
  wanderSessions   WanderSession[]
  wanderSummaries  WanderSummary[]
  acceptedInsights AcceptedInsight[]
  friends          Friend[]          @relation("UserFriends")
  isFriendOf       Friend[]          @relation("UserIsFriend")

  @@map("users")
}

// 知识广场话题
model Topic {
  id          String   @id @default(cuid())
  title       String // 话题标题
  content     String? // 话题描述/内容
  source      String // zhihu: 知乎热词, user_submitted: 用户提交
  sourceId    String? // 来源 ID（如知乎话题 ID）
  sourceUrl   String? // 来源链接
  status      String   @default("active") // active: 活跃, archived: 已归档
  publishedAt DateTime @default(now()) // 发布时间
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 关联
  posts         Post[]
  subscriptions Subscription[]

  @@unique([source, sourceId]) // 防止重复导入
  @@map("topics")
}

// 帖子/留言
model Post {
  id         String @id @default(cuid())
  content    String // 帖子内容
  authorType String // user: 用户发布, agent: Agent 发布

  topicId  String
  authorId String // 作者 ID（用户 ID）
  parentId String? // 父帖子 ID（回复某帖子时）

  topic   Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)
  author  User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  Post?  @relation("PostReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies Post[] @relation("PostReplies")

  createdAt DateTime @default(now())

  @@map("posts")
}

// 用户订阅
model Subscription {
  id          String    @id @default(cuid())
  lastVisitAt DateTime? // 上次访问时间（用于 2 小时冷却）
  unreadCount Int       @default(0) // 自上次 wander read_topic 以来的新帖数

  userId  String
  topicId String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic   Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, topicId])
  @@map("subscriptions")
}

// Agent 任务队列
model AgentTask {
  id      String  @id @default(cuid())
  type    String // read_topic: 阅读话题, generate_post: 生成回复
  payload Json // 任务参数
  status  String  @default("pending") // pending: 待处理, processing: 处理中, done: 完成, failed: 失败
  error   String? // 错误信息

  userId          String
  wanderSessionId String? // 所属的 wander session（可选）
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  wanderSession   WanderSession? @relation(fields: [wanderSessionId], references: [id], onDelete: SetNull)

  scheduledAt DateTime  @default(now()) // 计划执行时间
  completedAt DateTime? // 完成时间
  createdAt   DateTime  @default(now())

  @@index([status, scheduledAt])
  @@index([wanderSessionId, status])
  @@map("agent_tasks")
}

// Wander 会话：每次 wander 创建一个 session，追踪本次 wander 进度
model WanderSession {
  id          String @id @default(cuid())
  totalTopics Int    @default(0) // 本次计划处理的话题数量
  status      String @default("pending") // pending: 进行中, completed: 已完成

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  agentTasks    AgentTask[]
  wanderSummary WanderSummary?

  createdAt DateTime @default(now())

  @@index([userId, status])
  @@map("wander_sessions")
}

// Wander 总结报告：每次 wander 结束后生成，替代 per-topic Report
model WanderSummary {
  id      String @id @default(cuid())
  content Json // { topics: [{topicId, title, insights, recommended, reason}], overallTakeaways, generatedAt }

  userId        String
  sessionId     String        @unique
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  wanderSession WanderSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  acceptedInsights AcceptedInsight[]

  @@index([userId, createdAt])
  @@map("wander_summaries")
}

// 用户接受的话题启发：记录已接受并同步到 SecondMe 知识库的启发条目
model AcceptedInsight {
  id           String @id @default(cuid())
  insightIndex Int // 在 topic.insights 数组中的下标
  insightText  String // 发送到 SecondMe 时保存的启发文本快照
  eventId      Int? // SecondMe agent_memory 上报返回的 eventId

  userId    String
  summaryId String
  topicId   String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  summary   WanderSummary @relation(fields: [summaryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([summaryId, topicId, insightIndex])
  @@index([userId])
  @@map("accepted_insights")
}

// 关注关系：用户单向关注其他用户（秘密关注，对方不感知）
model Friend {
  id       String @id @default(cuid())
  userId   String // 关注者
  friendId String // 被关注者

  user   User @relation("UserFriends", fields: [userId], references: [id], onDelete: Cascade)
  friend User @relation("UserIsFriend", fields: [friendId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, friendId])
  @@index([userId])
  @@map("friends")
}
